{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "${giornoSettimana}",
          "color": "attention",
          "weight": "bolder",
          "horizontalAlignment": "center",
          "size": "small"
        },
        {
          "type": "TextBlock",
          "text": "${numeroGiorno}",
          "size": "extraLarge",
          "horizontalAlignment": "center",
          "weight": "bolder",
          "margin": "none"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io",
  "version": "1.5"
}
